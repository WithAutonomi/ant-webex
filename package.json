{
  "name": "ant-webex",
  "version": "0.1.1",
  "private": true,
  "description": "Browser extension for downloading content from the Autonomi decentralized network",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "build:firefox": "node build.mjs --firefox",
    "build:all": "node build.mjs && node build.mjs --firefox",
    "watch": "node build.mjs --watch",
    "watch:firefox": "node build.mjs --firefox --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test \"src/**/*.test.ts\"",
    "clean": "rm -rf dist dist-firefox"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0"
  }
}
